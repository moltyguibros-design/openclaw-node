#!/usr/bin/env bash
# bin/screenshot — Capture desktop screenshot for OpenClaw
# Usage: screenshot [--display N] [--delay N] [--clipboard] [output_path]
#
# Cross-platform: macOS (screencapture), Linux (scrot/gnome-screenshot/import)
# Defaults: full main display, no delay, saved to .tmp/screenshots/<timestamp>.png
# Returns: absolute path to captured image on stdout

set -euo pipefail

WORKSPACE="${OPENCLAW_WORKSPACE:-$(cd "$(dirname "$0")/.." && pwd)}"
SCREENSHOT_DIR="$WORKSPACE/.tmp/screenshots"
mkdir -p "$SCREENSHOT_DIR"

# Defaults
DELAY=""
DELAY_SECS=0
CLIPBOARD=false
OUTPUT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    --display|-D) shift 2 ;;  # display selection (macOS only, ignored on Linux)
    --delay|-T) DELAY_SECS="$2"; shift 2 ;;
    --clipboard|-c) CLIPBOARD=true; shift ;;
    --help|-h)
      echo "Usage: screenshot [--delay N] [--clipboard] [output_path]"
      echo ""
      echo "Options:"
      echo "  --delay N     Wait N seconds before capture"
      echo "  --clipboard   Also copy to clipboard"
      echo "  output_path   Custom output path (default: .tmp/screenshots/<timestamp>.png)"
      exit 0
      ;;
    *) OUTPUT="$1"; shift ;;
  esac
done

# Generate output path if not provided
if [[ -z "$OUTPUT" ]]; then
  TIMESTAMP=$(date +"%Y-%m-%d_%H-%M-%S")
  OUTPUT="$SCREENSHOT_DIR/${TIMESTAMP}.png"
fi

detect_os() {
  case "$(uname -s)" in
    Darwin) echo "macos" ;;
    Linux)  echo "linux" ;;
    *)      echo "unknown" ;;
  esac
}

OS=$(detect_os)

capture_macos() {
  local args=(-x)  # silent
  [[ "$DELAY_SECS" -gt 0 ]] && args+=("-T$DELAY_SECS")
  $CLIPBOARD && args+=(-c)
  args+=("$OUTPUT")
  screencapture "${args[@]}" 2>/dev/null
}

capture_linux() {
  [[ "$DELAY_SECS" -gt 0 ]] && sleep "$DELAY_SECS"

  if command -v scrot >/dev/null 2>&1; then
    scrot "$OUTPUT"
    $CLIPBOARD && command -v xclip >/dev/null 2>&1 && xclip -selection clipboard -t image/png -i "$OUTPUT"
  elif command -v gnome-screenshot >/dev/null 2>&1; then
    gnome-screenshot -f "$OUTPUT"
    $CLIPBOARD && command -v xclip >/dev/null 2>&1 && xclip -selection clipboard -t image/png -i "$OUTPUT"
  elif command -v import >/dev/null 2>&1; then
    import -window root "$OUTPUT"
  elif command -v flameshot >/dev/null 2>&1; then
    flameshot full -p "$(dirname "$OUTPUT")" -r > "$OUTPUT"
  else
    echo "ERROR: No screenshot tool found. Install one of: scrot, gnome-screenshot, flameshot, imagemagick" >&2
    exit 1
  fi
}

case "$OS" in
  macos)  capture_macos ;;
  linux)  capture_linux ;;
  *)
    echo "ERROR: Unsupported platform for screenshots" >&2
    exit 1
    ;;
esac

if [[ -f "$OUTPUT" ]]; then
  echo "$OUTPUT"
else
  echo "ERROR: Screenshot capture failed — no file at $OUTPUT" >&2
  exit 1
fi
