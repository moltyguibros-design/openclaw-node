# OpenClaw Node Configuration
# Copy to ~/.openclaw/openclaw.env and fill in your values.
# Lines starting with # are comments. Empty values are fine for optional services.

# ─── Node Identity ───────────────────────────────────────
OPENCLAW_NODE_ID=my-node
OPENCLAW_TIMEZONE=America/Montreal

# ─── AI Provider Keys ────────────────────────────────────
# At least one AI provider is needed for the gateway to function.
# GOOGLE_API_KEY is also used for Mission Control TTS (Gemini).
OPENAI_API_KEY=
GOOGLE_API_KEY=
ANTHROPIC_API_KEY=

# ─── Messaging Channels (optional) ───────────────────────
# Leave empty if not using Discord/Telegram integration.
DISCORD_BOT_TOKEN=
TELEGRAM_BOT_TOKEN=

# ─── Web Search (optional) ───────────────────────────────
WEB_SEARCH_API_KEY=

# ─── Obsidian Vault Sync (optional) ──────────────────────
# Only needed if running Obsidian with the Local REST API plugin.
OBSIDIAN_API_KEY=
